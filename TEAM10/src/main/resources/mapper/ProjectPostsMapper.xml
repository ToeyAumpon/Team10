    <!-- 新着順（明示） -->
    <select id="findAllOrderByDateDesc"
            resultType="com.example.demo.mapper.ProjectPosts">
        SELECT post_id, user_id, username, title, content, tag, post_date
        FROM POSTS
        ORDER BY post_date DESC
    </select>

    <!-- 古い順 -->
    <select id="findAllOrderByDateAsc"
            resultType="com.example.demo.mapper.ProjectPosts">
        SELECT post_id, user_id, username, title, content, tag, post_date
        FROM POSTS
        ORDER BY post_date ASC
    </select>

    <!-- ユーザーIDで取得 -->
    <select id="findByUserId"
            parameterType="long"
            resultType="com.example.demo.mapper.ProjectPosts">
        SELECT post_id, user_id, username, title, content, tag, post_date
        FROM POSTS
        WHERE user_id = #{user_id}
        ORDER BY post_date DESC
    </select>


 

<!--     検索 -->
    <select id="search"
            parameterType="string"
            resultType="com.example.demo.mapper.ProjectPosts">
        SELECT post_id, user_id, username, title, content, tag, post_date
        FROM POSTS
        WHERE title LIKE CONCAT('%', #{keyword}, '%')
        OR content LIKE CONCAT('%', #{keyword}, '%')
<!--        OR tag LIKE CONCAT('%', #{keyword}, '%')-->
        ORDER BY post_date DESC
