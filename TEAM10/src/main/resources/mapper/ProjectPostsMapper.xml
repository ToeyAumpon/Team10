<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.mapper.ProjectPostsMapper">

    <!-- IDで取得 -->
    <select id="findById"
            parameterType="long"
            resultType="com.example.demo.mapper.ProjectPosts">
        SELECT post_id, user_id, username, title, content, tag, post_date
        FROM POSTS
        WHERE post_id = #{post_id}
    </select>

    <!-- 投稿INSERT -->
    <insert id="insert"
            parameterType="com.example.demo.mapper.ProjectPosts"
            useGeneratedKeys="true"
            keyProperty="post_id">
        INSERT INTO POSTS (user_id, username, title, content, tag)
        VALUES (#{user_id}, #{username}, #{title}, #{content}, #{tag})
    </insert>

    <!-- デフォルト（新着順） -->
    <select id="findAll"
            resultType="com.example.demo.mapper.ProjectPosts">
        SELECT post_id, user_id, username, title, content, tag, post_date
        FROM POSTS
        ORDER BY post_date DESC
    </select>


    
