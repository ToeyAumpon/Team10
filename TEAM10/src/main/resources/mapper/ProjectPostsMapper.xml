	<!-- 投稿者名で投稿一覧を取得 -->
<select id="findByUsername"
parameterType="string"
resultType="com.example.demo.mapper.ProjectPosts">
SELECT post_id, user_id, username, title, content, tag, post_date
FROM POSTS
WHERE username = #{username}
ORDER BY post_id DESC
</select>
	
    

<select id="findByTagName" parameterType="string" resultType="com.example.demo.mapper.ProjectPosts">
SELECT DISTINCT p.* 
FROM posts p 
JOIN post_tags pt ON p.post_id = pt.post_id 
JOIN tags t ON pt.tag_id = t.tag_id
<!--        SELECT * FROM TAGS WHERE tag_name = #{tag}-->
WHERE t.tag_name = #{tag}
</select>
    

